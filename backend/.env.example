# ============================================================
# 后端环境变量示例
# 复制为 ../.env 后填入实际值（后端从项目根 .env 加载）
# ============================================================

# Database — PostgreSQL (生产)
DATABASE_URL=postgresql+psycopg://app:app@localhost:5432/auto_finance

# Database — SQLite (仅本地开发兼容)
# DATABASE_PATH=./data/npl.db

# Redis (Task 8 起需要)
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=change-me-to-random-string
JWT_REFRESH_SECRET=change-me-to-another-random-string

# CORS
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# File Storage
STORAGE_BACKEND=local
# S3_ENDPOINT=http://localhost:9000
# S3_BUCKET=auto-finance
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin

# 车300 API
CHE300_ACCESS_KEY=your_access_key
CHE300_ACCESS_SECRET=your_secret_key
CHE300_API_BASE=https://cloud-api.che300.com
DEFAULT_CITY_CODE=320100
DEFAULT_CITY_NAME=南京

# DeepSeek LLM
DEEPSEEK_API_KEY=your_deepseek_key
DEEPSEEK_BASE_URL=https://api.deepseek.com
