# ============================================================
# 生产环境配置 — 部署前必须修改标记 CHANGE_ME 的值
# ============================================================

# 你的域名（不带 https://）
DOMAIN=your-domain.com

# ──── 数据库 ────
DB_USER=app
DB_PASSWORD=CHANGE_ME_db_password_here
DB_NAME=auto_finance

# ──── JWT 密钥（用 openssl rand -hex 32 生成） ────
JWT_SECRET=CHANGE_ME_jwt_secret_here
JWT_REFRESH_SECRET=CHANGE_ME_jwt_refresh_secret_here

# ──── MinIO / S3 存储 ────
S3_ACCESS_KEY=CHANGE_ME_minio_access
S3_SECRET_KEY=CHANGE_ME_minio_secret
S3_BUCKET=auto-finance

# ──── 车300 API ────
CHE300_ACCESS_KEY=your_che300_key
CHE300_ACCESS_SECRET=your_che300_secret
CHE300_API_BASE=https://cloud-api.che300.com
DEFAULT_CITY_CODE=320100
DEFAULT_CITY_NAME=南京

# ──── DeepSeek LLM（可选，留空则用 Mock） ────
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
